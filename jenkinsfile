pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/YOUR_USERNAME/jenkins-k8s-cicd.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t nithiyab12/cicd-nodejs-app:latest .'
            }
        }

        stage('Push Docker Image') {
            steps {
                sh 'docker push nithiyab12/cicd-nodejs-app:latest'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f deployment.yaml'
                sh 'kubectl apply -f service.yaml'
            }
        }

    }
}